class Solution(object):
    def findMaximumXOR(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        max_xor = 0
        mask = 0

        for bit in range(31, -1, -1):
            mask |= (1 << bit)

            prefixes = set()
            for num in nums:
                prefixes.add(num & mask)

            candidate = max_xor | (1 << bit)

            found = False
            for p in prefixes:
                if (candidate ^ p) in prefixes:
                    found = True
                    break

            if found:
                max_xor = candidate

        return max_xor
