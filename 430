"""
# Definition for a Node.
class Node(object):
    def __init__(self, val, prev, next, child):
        self.val = val
        self.prev = prev
        self.next = next
        self.child = child
"""

class Solution(object):
    def flatten(self, head):
        """
        :type head: Node
        :rtype: Node
        """

        def dfs(node):
            curr = node
            last = None

            while curr:
                nxt = curr.next

                if curr.child:
                    child_head = curr.child
                    child_tail = dfs(child_head)

                    curr.next = child_head
                    child_head.prev = curr

                    curr.child = None

                    if nxt:
                        child_tail.next = nxt
                        nxt.prev = child_tail

                    last = child_tail
                else:
                    last = curr

                curr = nxt

            return last

        if head:
            dfs(head)

        return head
