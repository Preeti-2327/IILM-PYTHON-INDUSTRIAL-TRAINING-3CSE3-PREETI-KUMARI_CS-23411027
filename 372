class Solution(object):
    def superPow(self, a, b):
        """
        :type a: int
        :type b: List[int]
        :rtype: int
        """
        MOD = 1337

        result = 1
        a %= MOD

        for digit in b:
            result = (pow(result, 10, MOD) * pow(a, digit, MOD)) % MOD

        return result
