# The guess API is already defined for you.
# def guess(num):

class Solution(object):
    def guessNumber(self, n):
        """
        :type n: int
        :rtype: int
        """
        left, right = 1, n

        while left <= right:
            mid = left + (right - left) // 2
            res = guess(mid)

            if res == 0:
                return mid
            elif res < 0:  # guess is too high
                right = mid - 1
            else:          # guess is too low
                left = mid + 1
