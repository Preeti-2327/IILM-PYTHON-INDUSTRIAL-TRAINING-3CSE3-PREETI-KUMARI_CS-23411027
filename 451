from collections import Counter

class Solution(object):
    def frequencySort(self, s):
        """
        :type s: str
        :rtype: str
        """
        freq = Counter(s)

        ans = []

        for ch, count in sorted(freq.items(), key=lambda x: x[1], reverse=True):
            ans.append(ch * count)

        return "".join(ans)
