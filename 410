class Solution(object):
    def splitArray(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        left = max(nums)
        right = sum(nums)

        while left < right:
            mid = (left + right) // 2

            count = 1
            curr_sum = 0

            for num in nums:
                if curr_sum + num > mid:
                    count += 1
                    curr_sum = num
                else:
                    curr_sum += num

            if count > k:
                left = mid + 1
            else:
                right = mid

        return left
