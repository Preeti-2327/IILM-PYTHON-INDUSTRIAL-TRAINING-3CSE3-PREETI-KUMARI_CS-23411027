class Solution(object):
    def countMajoritySubarrays(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: int
        """
        n = len(nums)

        # Prefix sums after transforming:
        # target -> +1, others -> -1
        pref = [0]
        s = 0
        for x in nums:
            if x == target:
                s += 1
            else:
                s -= 1
            pref.append(s)

        # Coordinate compression
        vals = sorted(set(pref))
        rank = {v: i + 1 for i, v in enumerate(vals)}

        m = len(vals)
        bit = [0] * (m + 2)

        def update(i):
            while i <= m:
                bit[i] += 1
                i += i & -i

        def query(i):
            res = 0
            while i > 0:
                res += bit[i]
                i -= i & -i
            return res

        ans = 0

        for p in pref:
            idx = rank[p]
            # Count previous prefix sums strictly smaller
            ans += query(idx - 1)
            update(idx)

        return ans
