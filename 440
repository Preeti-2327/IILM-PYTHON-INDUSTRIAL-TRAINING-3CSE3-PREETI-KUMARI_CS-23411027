class Solution(object):
    def findKthNumber(self, n, k):
        """
        :type n: int
        :type k: int
        :rtype: int
        """

        def count_steps(n, curr, nxt):
            steps = 0

            while curr <= n:
                steps += min(n + 1, nxt) - curr
                curr *= 10
                nxt *= 10

            return steps

        curr = 1
        k -= 1  # first number is 1

        while k > 0:
            steps = count_steps(n, curr, curr + 1)

            if steps <= k:
                curr += 1      # move to next sibling
                k -= steps
            else:
                curr *= 10     # move to first child
                k -= 1

        return curr
