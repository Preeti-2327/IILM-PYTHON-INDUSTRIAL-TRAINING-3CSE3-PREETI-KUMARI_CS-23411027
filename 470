# The rand7() API is already defined for you.
# def rand7():
#     ...

class Solution(object):
    def rand10(self):
        """
        :rtype: int
        """
        while True:
            num = (rand7() - 1) * 7 + rand7()   # Uniform in [1, 49]

            if num <= 40:
                return (num - 1) % 10 + 1
