class Node:
    def __init__(self, count):
        self.count = count
        self.keys = set()
        self.prev = None
        self.next = None


class AllOne(object):

    def __init__(self):
        self.head = Node(0)  # dummy head
        self.tail = Node(0)  # dummy tail

        self.head.next = self.tail
        self.tail.prev = self.head

        self.key_to_node = {}

    def _insert_after(self, prev_node, new_node):
        nxt = prev_node.next

        prev_node.next = new_node
        new_node.prev = prev_node

        new_node.next = nxt
        nxt.prev = new_node

    def _remove_node(self, node):
        node.prev.next = node.next
        node.next.prev = node.prev

    def inc(self, key):
        if key not in self.key_to_node:
            first = self.head.next

            if first != self.tail and first.count == 1:
                first.keys.add(key)
                self.key_to_node[key] = first
            else:
                node = Node(1)
                node.keys.add(key)

                self._insert_after(self.head, node)
                self.key_to_node[key] = node

        else:
            cur = self.key_to_node[key]
            nxt = cur.next
            new_count = cur.count + 1

            if nxt != self.tail and nxt.count == new_count:
                nxt.keys.add(key)
                self.key_to_node[key] = nxt
            else:
                node = Node(new_count)
                node.keys.add(key)

                self._insert_after(cur, node)
                self.key_to_node[key] = node

            cur.keys.remove(key)

            if not cur.keys:
                self._remove_node(cur)

    def dec(self, key):
        cur = self.key_to_node[key]

        if cur.count == 1:
            del self.key_to_node[key]
        else:
            prev = cur.prev
            new_count = cur.count - 1

            if prev != self.head and prev.count == new_count:
                prev.keys.add(key)
                self.key_to_node[key] = prev
            else:
                node = Node(new_count)
                node.keys.add(key)

                self._insert_after(prev, node)
                self.key_to_node[key] = node

        cur.keys.remove(key)

        if not cur.keys:
            self._remove_node(cur)

    def getMaxKey(self):
        if self.tail.prev == self.head:
            return ""

        return next(iter(self.tail.prev.keys))

    def getMinKey(self):
        if self.head.next == self.tail:
            return ""

        return next(iter(self.head.next.keys))
