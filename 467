class Solution(object):
    def findSubstringInWraproundString(self, s):
        """
        :type s: str
        :rtype: int
        """
        dp = [0] * 26
        curr_len = 0

        for i in range(len(s)):
            if i > 0 and (ord(s[i]) - ord(s[i - 1])) % 26 == 1:
                curr_len += 1
            else:
                curr_len = 1

            idx = ord(s[i]) - ord('a')
            dp[idx] = max(dp[idx], curr_len)

        return sum(dp)
